NEXT_PUBLIC_API_URL=http://localhost:8080
# Chỉ dùng khi chạy storefront TRONG Docker: URL nội bộ cho fetch phía server.
# Khi chạy `npm run dev` ở host thì để trống (sẽ fallback về NEXT_PUBLIC_API_URL).
# INTERNAL_API_URL=http://api-gateway:8080
# Google OAuth Web client ID (Console → Credentials → OAuth client ID → Web application).
# Để trống nếu không demo Google Sign-In — nút Google sẽ tự ẩn.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
