# ============================================================
# THLuxury — Environment template
# Copy file này thành `infra/.env` rồi điền giá trị thật.
# KHÔNG commit file `.env` (đã có trong .gitignore).
# ============================================================

# ---------- Compose project name (network/volume prefix) ----------
COMPOSE_PROJECT_NAME=thluxury

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=thluxury

# Per-service DB users (created by 01-create-roles.sql)
DB_PASSWORD_IDENTITY=svc_identity_pw
DB_PASSWORD_CATALOG=svc_catalog_pw
DB_PASSWORD_INVENTORY=svc_inventory_pw
DB_PASSWORD_ORDER=svc_order_pw
DB_PASSWORD_PAYMENT=svc_payment_pw

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- RabbitMQ ----------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin

# ---------- Mail (MailHog dev) ----------
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=no-reply@thluxury.local

# ---------- JWT (RS256) ----------
# Đường dẫn keypair trong container Identity Service
JWT_PRIVATE_KEY_PATH=/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt-public.pem
JWT_ISSUER=https://thluxury.local
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ---------- Google OAuth2 (Identity Service) ----------
# Tạo tại https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8081/api/auth/oauth2/callback/google

# ---------- Payment ----------
# Mock gateway
PAYMENT_MOCK_FAILURE_RATE=0.2
PAYMENT_MOCK_MAX_DELAY_MS=3000
# Stripe sandbox (optional)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------- AI Service ----------
# Lấy free key tại https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE=http://localhost:8080
VITE_API_BASE=http://localhost:8080

# ---------- Observability ----------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
